# ============================================================
#  Nevera CMMS — Environment Variables Template
#  Copy this to .env on your server and fill in real values.
#  NEVER commit .env to version control.
# ============================================================

# Generate with:
# python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_STRING

# Always False in production
DEBUG=False

# Your domain (comma-separated, no spaces)
ALLOWED_HOSTS=nevera.neverno.in,www.nevera.neverno.in

# Used to build QR code URLs — must match your domain exactly
SITE_BASE_URL=https://nevera.neverno.in

# Timezone
TIME_ZONE=Asia/Kolkata

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING
